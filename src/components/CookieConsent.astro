---
// Lightweight, no-dependency cookie consent.
// Stores preferences in localStorage; no cookies are set by this component itself.
---

<div id="cookie-consent" class="cc" hidden>
	<div class="ccBar" role="dialog" aria-label="Cookie policy">
		<div class="ccTextWrap">
			<div class="ccTitle">Cookie policy</div>
			<p class="ccText">
				This site uses cookies. You can accept or reject cookies. You can change your decision any time via
				<a href="/cookie-settings">Cookie settings</a>.
			</p>
		</div>

		<div class="ccActions">
			<button class="ccBtn" id="cc-reject" type="button">Reject all</button>
			<button class="ccBtnPrimary" id="cc-accept-all" type="button">Accept all</button>
		</div>
	</div>
</div>

<script is:inline>
	(() => {
		// Bump version to ensure the popup shows again.
		const KEY = 'gg_cookie_consent_v4';

		function getStored() {
			try {
				const raw = localStorage.getItem(KEY);
				return raw ? JSON.parse(raw) : null;
			} catch {
				return null;
			}
		}

		function store(value) {
			try {
				localStorage.setItem(KEY, JSON.stringify(value));
			} catch {
				// ignore
			}
		}

		function close() {
			const root = document.getElementById('cookie-consent');
			if (root) root.hidden = true;
		}

		function open() {
			const root = document.getElementById('cookie-consent');
			if (root) root.hidden = false;
		}

		function init() {
			const existing = getStored();
			if (!existing) open();

			// Use event delegation (capture) so clicks always work even if the DOM
			// is replaced or the script runs before individual nodes exist.
			document.addEventListener(
				'click',
				(e) => {
					const t = e.target;
					const el =
						t instanceof Element
							? t
							: t instanceof Node && t.parentElement instanceof Element
								? t.parentElement
								: null;
					if (!el) return;

					const btn = el.closest('button');
					if (!(btn instanceof HTMLButtonElement)) return;

					if (btn.id === 'cc-accept-all') {
						e.preventDefault();
						store({ accepted: true, updatedAt: new Date().toISOString() });
						close();
					}

					if (btn.id === 'cc-reject') {
						e.preventDefault();
						store({
							accepted: false,
							updatedAt: new Date().toISOString(),
						});
						close();
					}
				},
				true
			);
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init, { once: true });
		} else {
			init();
		}
	})();
</script>

<style>
	.cc {
		position: fixed;
		left: 0;
		right: 0;
		bottom: 0;
		padding: 14px 16px 16px;
		z-index: 50;
	}

	.cc[hidden] {
		display: none !important;
	}

	.ccBar {
		max-width: 1000px;
		/* Same bar as before, just right-aligned. */
		margin: 0 0 0 auto;
		background: rgba(255, 255, 255, 0.94);
		border: 1px solid rgba(15, 23, 42, 0.12);
		border-radius: 14px;
		padding: 12px 12px 12px 14px;
		box-shadow: 0 14px 40px rgba(0, 0, 0, 0.18);
		backdrop-filter: blur(10px);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
	}

	.ccTextWrap {
		min-width: 0;
	}

	.ccTitle {
		font-size: 14px;
		font-weight: 600;
		letter-spacing: -0.01em;
		margin-bottom: 2px;
		color: rgba(15, 23, 42, 0.92);
	}

	.ccText {
		margin: 0;
		color: #4b5563;
		font-size: 14px;
		line-height: 1.5;
		text-align: left;
		hyphens: none;
	}

	.ccActions {
		display: flex;
		gap: 10px;
		justify-content: flex-end;
		flex-wrap: wrap;
		margin-top: 10px;
	}

	.ccBtn,
	.ccBtnPrimary {
		border-radius: 10px;
		padding: 10px 12px;
		font-size: 14px;
		border: 1px solid #e5e7eb;
		background: white;
		color: #111827;
		cursor: pointer;
	}

	.ccBtn:hover {
		background: #f9fafb;
	}

	.ccBtnPrimary {
		background: #111827;
		color: white;
		border-color: #111827;
	}

	.ccBtnPrimary:hover {
		background: #0b1220;
	}

	@media (max-width: 720px) {
		.ccBar {
			flex-direction: column;
			align-items: stretch;
		}
		.ccActions {
			justify-content: flex-start;
			margin-top: 0;
		}
	}
</style>

