---
import SiteNav from '../components/SiteNav.astro';

type Props = {
  title?: string;
  description?: string;
};

const { title = 'george guitars', description } = Astro.props;
const canonical = new URL(Astro.url.pathname, import.meta.env.SITE);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description ? <meta name="description" content={description} /> : null}
		<link rel="canonical" href={canonical} />

		<meta property="og:site_name" content="george guitars" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		{description ? <meta property="og:description" content={description} /> : null}
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
	</head>
	<body>
		<div class="site">
			<header class="header">
				<nav class="nav">
					<a class="brand" href="/">george guitars</a>
					<div class="navLinks">
						<SiteNav />
						<a href="/contact">contact</a>
					</div>
				</nav>
			</header>

			<main class="main">
				<slot />
			</main>

			<footer class="footer">
				<div class="footerInner">
					<span>© {new Date().getFullYear()} george guitars</span>
					<div class="footerLinks">
						<a href="https://www.instagram.com/downtoearthexplorersband/" target="_blank" rel="noreferrer"
							>instagram</a
						>
						<a href="https://linktr.ee/dtee_em" target="_blank" rel="noreferrer">linktree</a>
						<a href="/contact">contact</a>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	:root {
		/* Approximated from the current live site (refine later). */
		--bg: #fbfbfa;
		--fg: #0f172a;
		--muted: #475569;
		--rule: rgba(15, 23, 42, 0.10);
		--link: #0f172a;
		--linkHover: rgba(15, 23, 42, 0.60);
		--max: 920px;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--fg);
	}

	body {
		font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial,
			"Apple Color Emoji", "Segoe UI Emoji";
		line-height: 1.6;
		letter-spacing: -0.01em;
	}

	a {
		color: var(--link);
		text-decoration: none;
	}
	a:hover {
		color: var(--linkHover);
	}

	.site {
		min-height: 100dvh;
		display: flex;
		flex-direction: column;
	}

	.header {
		border-bottom: 1px solid var(--rule);
		background: #fcf4bb;
	}

	.nav {
		max-width: var(--max);
		margin: 0 auto;
		padding: 18px 16px;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
	}

	.brand {
		font-weight: 500;
		letter-spacing: -0.02em;
	}

	.navLinks {
		display: flex;
		align-items: baseline;
		gap: 18px;
		font-size: 14px;
		color: var(--muted);
	}
	.navLinks a {
		color: var(--muted);
		transition: color 0.2s;
	}
	.navLinks a:hover {
		color: var(--fg);
	}

	.main {
		flex: 1;
		max-width: var(--max);
		margin: 0 auto;
		padding: 28px 16px 44px;
	}

	h1,
	h2,
	h3 {
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	h1 {
		font-size: 28px;
		margin: 0 0 12px;
	}
	h2 {
		font-size: 18px;
		margin: 26px 0 10px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	h3 {
		font-size: 16px;
		margin: 18px 0 8px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	p {
		margin: 0 0 12px;
		color: var(--muted);
		text-align: justify;
		text-justify: inter-word;
		hyphens: auto;
	}

	ul {
		margin: 0 0 12px;
		padding-left: 18px;
		color: var(--muted);
	}
	li {
		margin: 6px 0;
		text-align: justify;
		text-justify: inter-word;
		hyphens: auto;
	}

	hr {
		border: 0;
		border-top: 1px solid var(--rule);
		margin: 28px 0;
	}

	.footer {
		border-top: 1px solid var(--rule);
	}

	.footerInner {
		max-width: var(--max);
		margin: 0 auto;
		padding: 18px 16px;
		display: flex;
		justify-content: space-between;
		gap: 16px;
		font-size: 12px;
		color: var(--muted);
	}
	.footerLinks {
		display: flex;
		gap: 14px;
		justify-content: flex-end;
		flex-wrap: wrap;
	}
	.footerInner a {
		color: var(--muted);
		transition: color 0.2s;
	}
	.footerInner a:hover {
		color: var(--fg);
	}
</style>
